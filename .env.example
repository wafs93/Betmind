# Required - OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-your-key-here

# Option A: football-data.org (RECOMMENDED - free, no credit card)
# Sign up at https://www.football-data.org/client/register
# Covers: Premier League, La Liga, Serie A, Bundesliga, Champions League, Ligue 1
FOOTBALL_DATA_KEY=your-football-data-key-here

# Option B: api-football.com (backup - also free 100 req/day)
# Get key at https://dashboard.api-football.com/profile
API_FOOTBALL_KEY=your-api-football-key-here
